<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/approval_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="‹ 뒤로"
                android:textColor="@color/text_hint"
                android:textSize="13sp"
                android:paddingVertical="14dp"
                android:paddingEnd="14dp"
                android:background="?attr/selectableItemBackground" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="대타 요청 승인"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- requester -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_warn"
                android:padding="13dp">

                <View
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_circle_warn" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_req_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="민지님의 대타 요청"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="승인 대기 · 2시간 전"
                        android:textColor="@color/warn_orange"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- detail rows -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="vertical">

                <LinearLayout style="@style/DetailRow">
                    <TextView style="@style/DetailKey" android:text="근무" />
                    <TextView android:id="@+id/tv_shift" style="@style/DetailVal" android:text="12/3 (수) 14:00–18:00" />
                </LinearLayout>
                <View style="@style/DetailDivider" />
                <LinearLayout style="@style/DetailRow">
                    <TextView style="@style/DetailKey" android:text="근무지" />
                    <TextView style="@style/DetailVal" android:text="강남점 · 홀" />
                </LinearLayout>
                <View style="@style/DetailDivider" />
                <LinearLayout style="@style/DetailRow">
                    <TextView style="@style/DetailKey" android:text="요청 대상" />
                    <TextView style="@style/DetailVal" android:text="전체 공개" />
                </LinearLayout>
                <View style="@style/DetailDivider" />
                <LinearLayout style="@style/DetailRow">
                    <TextView style="@style/DetailKey" android:text="지원자" />
                    <TextView android:id="@+id/tv_applicants" style="@style/DetailVal" android:text="없음" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_reason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_soft_gray"
                android:text="사유 · 개인 사정으로 어려워요"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:padding="11dp" />
        </LinearLayout>
    </ScrollView>

    <!-- action bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="20dp"
        android:baselineAligned="false">

        <TextView
            android:id="@+id/btn_reject"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_outline_gray"
            android:text="거절"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingVertical="15dp"
            android:foreground="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/btn_approve"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_btn_primary"
            android:text="승인하기"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingVertical="15dp"
            android:foreground="?attr/selectableItemBackground" />
    </LinearLayout>
</LinearLayout>
