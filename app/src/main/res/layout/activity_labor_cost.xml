<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/labor_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="28dp">

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="‹ 뒤로"
            android:textColor="@color/text_hint"
            android:textSize="13sp"
            android:paddingVertical="14dp"
            android:paddingEnd="14dp"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="이번 주 인건비"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="₩1,240,000"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="지난 주 대비 +8%"
            android:textColor="@color/brand"
            android:textSize="11sp"
            android:textStyle="bold" />

        <!-- weekly chart -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:baselineAligned="false">

            <View style="@style/Bar" android:layout_height="50dp" />
            <View style="@style/Bar" android:layout_height="86dp" />
            <View style="@style/Bar" android:layout_height="66dp" />
            <View style="@style/Bar" android:layout_height="110dp"
                android:background="@drawable/bg_bar_active" />
            <View style="@style/Bar" android:layout_height="62dp" />
            <View style="@style/Bar" android:layout_height="78dp" />
            <View style="@style/Bar" android:layout_height="40dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <TextView style="@style/ChartDay" android:text="월" />
            <TextView style="@style/ChartDay" android:text="화" />
            <TextView style="@style/ChartDay" android:text="수" />
            <TextView style="@style/ChartDay" android:text="목" android:textColor="@color/brand" />
            <TextView style="@style/ChartDay" android:text="금" />
            <TextView style="@style/ChartDay" android:text="토" />
            <TextView style="@style/ChartDay" android:text="일" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="알바별 인건비"
            android:textColor="#444444"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/cost_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:paddingHorizontal="14dp"
            android:paddingVertical="4dp">

            <TextView
                android:id="@+id/tv_cost_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:gravity="center"
                android:text="집계할 인건비가 없습니다."
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
