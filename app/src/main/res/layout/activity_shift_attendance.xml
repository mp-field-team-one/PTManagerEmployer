<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/att_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="뒤로" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="근무별 출근 현황"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="오늘 · 강남점"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- summary -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_soft_gray"
                android:padding="14dp"
                android:baselineAligned="false">

                <LinearLayout style="@style/SummaryCol">
                    <TextView android:id="@+id/tv_present" style="@style/SummaryNum" android:text="0" android:textColor="@color/accent_green" />
                    <TextView style="@style/SummaryLabel" android:text="출근" />
                </LinearLayout>

                <LinearLayout style="@style/SummaryCol">
                    <TextView android:id="@+id/tv_late" style="@style/SummaryNum" android:text="0" android:textColor="@color/warn_orange" />
                    <TextView style="@style/SummaryLabel" android:text="지각" />
                </LinearLayout>

                <LinearLayout style="@style/SummaryCol">
                    <TextView android:id="@+id/tv_absent" style="@style/SummaryNum" android:text="0" android:textColor="@color/accent_red" />
                    <TextView style="@style/SummaryLabel" android:text="결근" />
                </LinearLayout>
            </LinearLayout>

            <!-- rows -->
            <LinearLayout
                android:id="@+id/att_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:divider="@drawable/divider_line"
                android:showDividers="middle"
                android:padding="4dp">

                <TextView
                    android:id="@+id/tv_att_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:gravity="center"
                    android:text="오늘 예정된 근무가 없습니다."
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
